---
import '../styles/global.css'
import Chip from "../components/chip.astro";

const siteUrl = Astro.site ?? new URL("https://andres.reveronmolina.me");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const title = "Andrés Reverón Molina | Personal Website";
const description =
  "Personal site for Andrés Reverón Molina, with contact links, GitHub projects, and social profiles.";
const imageUrl = new URL("/favicon.svg", siteUrl);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": new URL("/#person", siteUrl).href,
      name: "Andrés Reverón Molina",
      url: canonicalUrl.href,
      email: "mailto:andres@reveronmolina.me",
      sameAs: [
        "https://github.com/systemallica",
        "https://bsky.app/profile/reveronmolina.me",
      ],
    },
    {
      "@type": "WebSite",
      "@id": new URL("/#website", siteUrl).href,
      name: "Andrés Reverón Molina",
      alternateName: "reveronmolina.me",
      url: canonicalUrl.href,
      publisher: {
        "@id": new URL("/#person", siteUrl).href,
      },
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.1/css/all.min.css"
      integrity="sha512-5Hs3dF2AEPkpNAR7UiOHba+lRSJNeM2ECkwxUIxC1Q/FLycGTbNapWXB4tP889k5T5Ju8fs4b1P5z/iB4nMfSQ=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl.href} />
    <meta name="description" content={description} />
    <meta name="author" content="Andrés Reverón Molina" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Andrés Reverón Molina" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:image" content={imageUrl.href} />
    <meta property="og:description" content={description} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:image" content={imageUrl.href} />
    <meta name="twitter:card" content="summary" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
    <title>{title}</title>
    <style>
      @font-face {
        font-family: Geist;
        src: url(/Geist.ttf);
        font-display: swap;
      }
    </style>
  </head>
  <body
    class="bg-[#1e1e1e] flex justify-center items-center w-screen h-screen font-[Geist] text-white"
  >
    <main class="w-[80%] flex flex-col gap-8">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-center">
        Andrés Reverón Molina
      </h1>
      <div class="flex justify-center gap-8">
        <Chip
          link="mailto:andres@reveronmolina.me"
          icon="fa-regular fa-envelope"
        />
        <Chip
          link="https://github.com/systemallica"
          icon="fa-brands fa-github"
        />
        <Chip
          link="https://bsky.app/profile/reveronmolina.me"
          icon="fa-brands fa-bluesky"
        />
      </div>
    </main>
  </body>
</html>
